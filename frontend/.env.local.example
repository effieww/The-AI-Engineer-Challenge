# Optional: only needed if the frontend and backend run on different hosts.
# Leave unset for local dev (Next.js rewrites to port 8000) and same-origin Vercel deploys.
# NEXT_PUBLIC_API_URL=https://your-backend.vercel.app

# Used by next.config.ts rewrites during `npm run dev` (default: http://127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000
